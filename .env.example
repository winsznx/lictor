# Somnia private key (no 0x prefix) — set manually, never commit
PRIVATE_KEY=your_private_key_here

# Somnia testnet RPC — default is the public endpoint
SOMNIA_TESTNET_RPC=https://api.infra.testnet.somnia.network

# Somnia mainnet RPC — default is the public endpoint
SOMNIA_MAINNET_RPC=https://api.infra.mainnet.somnia.network

# Deployed Day0Probe address (set after running script 01)
PROBE_ADDRESS=0x...

# Deployed Lictor addresses
LICTOR_ADDRESS=0x8c5f99096252e506d6fcbc28147395b4092bc01f
LICTOR_MAINNET_ADDRESS=0xf02c982d19184c11b86bc34672441c45fbf0f93e
MAINNET_DEPLOY_BLOCK=328480687
